CALCOM_HOST=agenda.example.com
CALCOM_API_HOST=agenda-api.example.com

DATABASE_URL=postgresql://calcom:replace-with-password@postgres.example.internal:5432/calcom
DATABASE_DIRECT_URL=postgresql://calcom:replace-with-password@postgres.example.internal:5432/calcom
DATABASE_READ_URL=postgresql://calcom:replace-with-password@postgres.example.internal:5432/calcom
DATABASE_WRITE_URL=postgresql://calcom:replace-with-password@postgres.example.internal:5432/calcom

NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
CALENDSO_ENCRYPTION_KEY=replace-with-openssl-rand-base64-24
JWT_SECRET=replace-with-openssl-rand-base64-32
CRON_API_KEY=replace-with-openssl-rand-hex-32
CRON_ENABLE_APP_SYNC=true

API_KEY_PREFIX=cal_
LOG_LEVEL=info
LOGGER_BRIDGE_LOG_LEVEL=1
CSP_POLICY=

EMAIL_FROM=notifications@agenda.example.com
EMAIL_FROM_NAME=Agenda
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=notifications@agenda.example.com
EMAIL_SERVER_PASSWORD=replace-with-smtp-password

GOOGLE_LOGIN_ENABLED=false
GOOGLE_API_CREDENTIALS={"web":{"client_id":"replace.apps.googleusercontent.com","project_id":"replace","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"replace","redirect_uris":["https://agenda.example.com/api/integrations/googlecalendar/callback","https://agenda.example.com/api/auth/callback/google"]}}
GOOGLE_CALENDAR_API_KEY=replace-with-google-calendar-api-key
GOOGLE_WEBHOOK_TOKEN=replace-with-openssl-rand-base64-32

MICROSOFT_WEBHOOK_TOKEN=replace-with-openssl-rand-base64-32
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

STRIPE_API_KEY=sk_test_dummy_replace_if_billing_is_enabled
STRIPE_WEBHOOK_SECRET=whsec_dummy_replace_if_billing_is_enabled

NEXT_PUBLIC_DISABLE_SIGNUP=false
CALCOM_TELEMETRY_DISABLED=1
TZ=UTC
